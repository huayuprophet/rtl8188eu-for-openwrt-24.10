+// ==========================================================
+// Ambil TX rate per STA
+// ==========================================================
+static void rtw_get_sta_txrate(_adapter *padapter, struct sta_info *psta, struct rate_info *rinfo)
+{
+    u8 rate;
+    u8 mcs;
+    u8 bw;
+    static const u16 legacy_rates[] = {
+        10, 20, 55, 110,   /* 1, 2, 5.5, 11 Mbps */
+        60, 90, 120, 180,  /* 6, 9, 12, 18 Mbps */
+        240, 360, 480, 540 /* 24, 36, 48, 54 Mbps */
+    };
+
+    memset(rinfo, 0, sizeof(struct rate_info));
+
+    /* Ambil rate dari firmware */
+    rate = psta->cmn.ra_info.curr_tx_rate;
+
+    /* ===== Fallback jika firmware lapor invalid ===== */
+    if (rate == 0x00 || rate == 0xFF || rate == 0xFE) {
+        if (psta->last_tx_rate)
+            rate = psta->last_tx_rate; /* pakai rate terakhir */
+        else if (psta->htpriv.ht_option)
+            rate = 0x87;               /* default MCS7 HT 1x1 */
+        else
+            rate = 11;                 /* fallback legacy 54 Mbps */
+    }
+
+    /* ===== Decode HT / Legacy ===== */
+    if (rate & 0x80) {
+        /* HT rate */
+        mcs = rate & 0x7F;
+        if (mcs > 7)
+            mcs = 7; /* Clamp RTL8188EU 1x1 */
+
+        rinfo->flags |= RATE_INFO_FLAGS_MCS;
+        rinfo->mcs = mcs;
+
+#if (LINUX_VERSION_CODE >= KERNEL_VERSION(4,0,0))
+        bw = psta->cmn.ra_info.ra_bw_mode;
+        rinfo->bw = (bw >= CHANNEL_WIDTH_40) ? RATE_INFO_BW_40 : RATE_INFO_BW_20;
+#endif
+
+        /* Short GI */
+        if (psta->htpriv.ht_cap.cap_info & (IEEE80211_HT_CAP_SGI_20 | IEEE80211_HT_CAP_SGI_40))
+            rinfo->flags |= RATE_INFO_FLAGS_SHORT_GI;
+
+    } else {
+        /* Legacy rate */
+        if (rate < ARRAY_SIZE(legacy_rates))
+            rinfo->legacy = legacy_rates[rate];
+        else
+            rinfo->legacy = 54; /* fallback */
+    }
+
+    /* Simpan rate valid terakhir */
+    psta->last_tx_rate = rate;
+}
+
+// ==========================================================
+// Ambil RX rate per STA
+// ==========================================================
+static void rtw_get_sta_rxrate(struct sta_info *psta, struct rate_info *rinfo)
+{
+    u8 rate;
+    u8 mcs;
+    u8 bw;
+
+    memset(rinfo, 0, sizeof(struct rate_info));
+
+    rate = psta->curr_rx_rate; /* RX terakhir unicast */
+    if (!rate)
+        return; /* belum ada paket RX */
+
+    if (rate & 0x80) {
+        /* HT */
+        mcs = rate & 0x7F;
+        if (mcs > 7)
+            mcs = 7;
+
+        rinfo->flags |= RATE_INFO_FLAGS_MCS;
+        rinfo->mcs = mcs;
+
+#if (LINUX_VERSION_CODE >= KERNEL_VERSION(4,0,0))
+        bw = psta->cmn.ra_info.ra_bw_mode;
+        rinfo->bw = (bw >= CHANNEL_WIDTH_40) ? RATE_INFO_BW_40 : RATE_INFO_BW_20;
+#endif
+
+        if (psta->htpriv.ht_cap.cap_info & (IEEE80211_HT_CAP_SGI_20 | IEEE80211_HT_CAP_SGI_40))
+            rinfo->flags |= RATE_INFO_FLAGS_SHORT_GI;
+
+    } else {
+        /* Legacy */
+        static const u16 legacy_rates[] = {
+            10, 20, 55, 110, 60, 90, 120, 180, 240, 360, 480, 540
+        };
+        if (rate < ARRAY_SIZE(legacy_rates))
+            rinfo->legacy = legacy_rates[rate];
+        else
+            rinfo->legacy = 54;
+    }
+}
