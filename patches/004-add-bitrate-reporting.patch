+// ==========================================================
+// Ambil TX rate per STA
+// ==========================================================
+static void rtw_get_sta_txrate(_adapter *padapter, struct sta_info *psta, struct rate_info *rinfo)
+{
+    u8 rate;
+    u8 mcs;
+    static const u16 legacy_rates[] = {
+        10, 20, 55, 110, 60, 90, 120, 180, 240, 360, 480, 540
+    };
+
+    memset(rinfo, 0, sizeof(struct rate_info));
+
+    /* Ambil dari Rate Adaptive (RA) info */
+    rate = psta->cmn.ra_info.curr_tx_rate;
+
+    /* Fallback */
+    if (rate == 0x00 || rate == 0xFF || rate == 0xFE) {
+        rate = (psta->last_tx_rate) ? psta->last_tx_rate : (psta->htpriv.ht_option ? 0x87 : 11);
+    }
+
+    if (rate & 0x80) {
+        /* HT rate (MCS) */
+        rinfo->flags |= RATE_INFO_FLAGS_MCS;
+        rinfo->mcs = (rate & 0x7F) > 7 ? 7 : (rate & 0x7F);
+
+#if (LINUX_VERSION_CODE >= KERNEL_VERSION(4,0,0))
+    if (psta->htpriv.ht_cap.cap_info & IEEE80211_HT_CAP_SUP_WIDTH) {
+        /* Cek apakah AP atau STA sedang dalam mode 40MHz */
+        if (psta->cmn.ra_info.ra_bw_mode >= CHANNEL_WIDTH_40)
+            rinfo->bw = RATE_INFO_BW_40;
+        else
+            rinfo->bw = RATE_INFO_BW_20;
+    } else {
+        rinfo->bw = RATE_INFO_BW_20;
+    }
+#endif
+
+        if (psta->htpriv.ht_cap.cap_info & (IEEE80211_HT_CAP_SGI_20 | IEEE80211_HT_CAP_SGI_40))
+            rinfo->flags |= RATE_INFO_FLAGS_SHORT_GI;
+
+    } else {
+        /* Legacy rate - Pastikan 540 (unit 100kbps) */
+        if (rate < ARRAY_SIZE(legacy_rates))
+            rinfo->legacy = legacy_rates[rate];
+        else
+            rinfo->legacy = 540; /* FIX: Dari 54 jadi 540 */
+    }
+
+    psta->last_tx_rate = rate;
+}
+
+// ==========================================================
+// Ambil RX rate per STA
+// ==========================================================
+static void rtw_get_sta_rxrate(struct sta_info *psta, struct rate_info *rinfo)
+{
+    u8 rate = psta->curr_rx_rate;
+    u8 mcs;
+    static const u16 legacy_rates[] = {
+        10, 20, 55, 110, 60, 90, 120, 180, 240, 360, 480, 540
+    };
+
+    memset(rinfo, 0, sizeof(struct rate_info));
+
+    /* Fallback jika data kosong/invalid */
+    if (rate == 0x00 || rate == 0xFF || rate == 0xFE) {
+        if (psta->last_rx_rate)
+            rate = psta->last_rx_rate;
+        else
+            rate = (psta->htpriv.ht_option) ? 0x87 : 0x0B; // Default MCS7 atau 54Mbps
+    }
+
+    if (rate & 0x80) {
+        /* Mode HT (MCS) */
+        mcs = rate & 0x7F;
+        if (mcs > 7) mcs = 7;
+
+        rinfo->flags |= RATE_INFO_FLAGS_MCS;
+        rinfo->mcs = mcs;
+
+#if (LINUX_VERSION_CODE >= KERNEL_VERSION(4,0,0))
+        rinfo->bw = (psta->cmn.ra_info.ra_bw_mode >= CHANNEL_WIDTH_40) ? 
+                    RATE_INFO_BW_40 : RATE_INFO_BW_20;
+#endif
+
+        if (psta->htpriv.ht_cap.cap_info & (IEEE80211_HT_CAP_SGI_20 | IEEE80211_HT_CAP_SGI_40))
+            rinfo->flags |= RATE_INFO_FLAGS_SHORT_GI;
+
+    } else {
+        /* Mode Legacy */
+        if (rate < ARRAY_SIZE(legacy_rates))
+            rinfo->legacy = legacy_rates[rate];
+        else
+            rinfo->legacy = 540; /* Pakai 540 agar tampil 54 MBit/s */
+    }
+
+    psta->last_rx_rate = rate;
+}
+
+// ==========================================================
+// Dump info STA untuk cfg80211
+// ==========================================================
+static int cfg80211_rtw_dump_station(struct wiphy *wiphy,
+                                     struct net_device *ndev,
+                                     int idx,
+                                     u8 *mac,
+                                     struct station_info *sinfo)
+{
+    int ret = 0;
+    _irqL irqL;
+    _adapter *padapter = (_adapter *)rtw_netdev_priv(ndev);
+    struct sta_priv *pstapriv = &padapter->stapriv;
+    struct sta_info *psta = NULL;
+    struct rate_info rinfo;
+    u8 asoc_list_num;
+
+    _enter_critical_bh(&pstapriv->asoc_list_lock, &irqL);
+    psta = rtw_sta_info_get_by_idx(pstapriv, idx, &asoc_list_num);
+    _exit_critical_bh(&pstapriv->asoc_list_lock, &irqL);
+
+    if (!psta) {
+        ret = -ENOENT;
+        goto exit;
+    }
+
+    _rtw_memcpy(mac, psta->cmn.mac_addr, ETH_ALEN);
+    sinfo->filled = 0;
+
+    /* SIGNAL & INACTIVE TIME */
+    sinfo->filled |= STATION_INFO_SIGNAL;
+    sinfo->signal = translate_percentage_to_dbm(psta->cmn.rssi_stat.rssi);
+    sinfo->filled |= STATION_INFO_INACTIVE_TIME;
+    sinfo->inactive_time = rtw_get_passing_time_ms(psta->sta_stats.last_rx_time);
+
+    /* TX BITRATE - Mapping Manual (Final Fix) */
+    rtw_get_sta_txrate(padapter, psta, &rinfo);
+    if (rinfo.legacy || (rinfo.flags & RATE_INFO_FLAGS_MCS)) {
+        sinfo->filled |= STATION_INFO_TX_BITRATE;
+        memset(&sinfo->txrate, 0, sizeof(sinfo->txrate));
+
+        if (rinfo.flags & RATE_INFO_FLAGS_MCS) {
+            sinfo->txrate.flags = RATE_INFO_FLAGS_MCS; 
+            sinfo->txrate.mcs = rinfo.mcs;
+            
+            /* Gunakan Macro agar tidak salah baca enum kernel */
+            sinfo->txrate.bw = (rinfo.bw == RATE_INFO_BW_40) ? RATE_INFO_BW_40 : RATE_INFO_BW_20;
+            sinfo->txrate.nss = 1; 
+            
+            if (rinfo.flags & RATE_INFO_FLAGS_SHORT_GI)
+                sinfo->txrate.flags |= RATE_INFO_FLAGS_SHORT_GI;
+        } else {
+            sinfo->txrate.legacy = rinfo.legacy;
+        }
+    }
+
+    /* RX BITRATE - Mapping Manual (Final Fix) */
+    rtw_get_sta_rxrate(psta, &rinfo);
+    if (rinfo.legacy || (rinfo.flags & RATE_INFO_FLAGS_MCS)) {
+        sinfo->filled |= STATION_INFO_RX_BITRATE;
+        memset(&sinfo->rxrate, 0, sizeof(sinfo->rxrate));
+        
+        if (rinfo.flags & RATE_INFO_FLAGS_MCS) {
+            sinfo->rxrate.flags = RATE_INFO_FLAGS_MCS;
+            sinfo->rxrate.mcs = rinfo.mcs;
+            
+            /* Gunakan Macro agar tidak salah baca enum kernel */
+            sinfo->rxrate.bw = (rinfo.bw == RATE_INFO_BW_40) ? RATE_INFO_BW_40 : RATE_INFO_BW_20;
+            sinfo->rxrate.nss = 1;
+            
+            if (rinfo.flags & RATE_INFO_FLAGS_SHORT_GI)
+                sinfo->rxrate.flags |= RATE_INFO_FLAGS_SHORT_GI;
+        } else {
+            sinfo->rxrate.legacy = rinfo.legacy;
+        }
+    }
 
 exit:
